{
  "name": "@emply/mcp-server",
  "version": "1.0.0",
  "description": "MCP server for the Emply PIX payment API",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "emply-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json"
  ],
  "keywords": [
    "mcp",
    "emply",
    "pix",
    "payments",
    "brazil"
  ],
  "license": "MIT"
}
